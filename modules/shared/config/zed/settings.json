{
  "cli_default_open_behavior": "new_window",
  "project_panel": {
    "dock": "left",
  },
  "outline_panel": {
    "dock": "left",
  },
  "git_panel": {
    "dock": "left",
  },
  "language_models": {
    "openai_compatible": {
      "TensorZero": {
        "api_url": "https://65f4-172-86-69-123.ngrok-free.app/openai/v1",
        "available_models": [
          {
            "name": "tensorzero::function_name::cursorzero9",
            "max_tokens": 200000,
            "max_output_tokens": 32000,
            "max_completion_tokens": 200000,
            "capabilities": {
              "tools": true,
              "images": false,
              "parallel_tool_calls": false,
              "prompt_cache_key": false,
              "chat_completions": true,
            },
          },
        ],
      },
    },
  },
  "debugger": {
    "dock": "bottom",
  },
  "icon_theme": {
    "mode": "light",
    "light": "Zed (Default)",
    "dark": "Zed (Default)",
  },
  "agent_servers": {
    "cursor": {
      "favorite_config_option_values": {
        "model": [
          "claude-sonnet-4-6[thinking=true,context=200k,effort=medium]",
          "claude-opus-4-6[thinking=true,context=200k,effort=high,fast=false]",
          "gemini-3-flash[]",
        ],
      },
      "type": "registry",
    },
  },
  "ssh_connections": [],
  "edit_predictions": {
    "provider": "zed",
    "mode": "eager",
  },
  "theme": {
    "mode": "light",
    "dark": "Oxocarbon Dark (IBM Carbon)",
    "light": "Oxocarbon Light (IBM Carbon)",
  },
  "telemetry": {
    "diagnostics": true,
    "metrics": false,
  },

  "ui_font_size": 16,
  "buffer_font_size": 14,
  "buffer_font_features": {
    "calt": false,
  },
  "soft_wrap": "bounded",
  "preferred_line_length": 100,

  "remove_trailing_whitespace_on_save": true,
  "ensure_final_newline_on_save": true,
  "extend_comment_on_newline": false,
  "autosave": "on_focus_change",

  "format_on_save": "on",
  "languages": {
    "YAML": {
      "formatter": "language_server",
      "show_whitespaces": "boundary",
      "format_on_save": "off",
    },
    "TypeScript": {
      "show_whitespaces": "boundary",
    },
    "C": { "format_on_save": "off" },
    "C++": { "format_on_save": "off" },
  },
  "lsp": {
    "rust-analyzer": {
      "initialization_options": {
        "checkOnSave": true,
        "initialization_options": {
          "inlayHints": {
            "maxLength": null,
            "lifetimeElisionHints": {
              "enable": "skip_trivial",
              "useParameterNames": true,
            },
            "closureReturnTypeHints": {
              "enable": "always",
            },
          },
        },
      },
    },
    "typos": {
      "initialization_options": {
        "config": "~/.config/typos.toml",
        "path": "typos-lsp",
      },
    },
  },
  "agent": {
    "sidebar_side": "right",
    "dock": "right",
    "default_model": {
      "provider": "openrouter",
      "model": "moonshotai/kimi-k2.6",
      "enable_thinking": true,
    },
    "default_profile": "write",
    "button": true,
  },
  "collaboration_panel": {
    "dock": "left",
    "button": false,
  },
  "search": { "button": false },
  "inlay_hints": {
    "enabled": false,
    "show_type_hints": true,
    "show_parameter_hints": true,
    "show_other_hints": true,
    "edit_debounce_ms": 700,
    "scroll_debounce_ms": 50,
  },
  "diagnostics": {
    "include_warnings": true,
    "inline": {
      "enabled": true,
      "update_debounce_ms": 150,
      "padding": 3,
      "min_column": 0,
    },
  },
  "gutter": {
    "line_numbers": true,
  },
  "terminal": {
    "shell": {
      "with_arguments": { "program": "zsh", "args": ["--login"] },
    },
  },
}
